{
    "name": "sirix/inertia-psr15",
    "description": "InertiaJS server-side adapter for PSR-7 and PSR-15 applications",
    "license": "BSD-3-Clause",
    "type": "library",
    "authors": [
        {
            "name": "Cherif BOUCHELAGHEM",
            "email": "cherif.bouchelaghem@gmail.com"
        },
        {
            "name": "Sirix",
            "email": "sirix@inbox.lv"
        }
    ],
    "require": {
        "php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
        "psr/http-server-middleware": "^1.0"
    },
    "require-dev": {
        "bamarni/composer-bin-plugin": "^1.8",
        "laminas/laminas-diactoros": "^3.6.0",
        "localheinz/diff": "^1.0",
        "mezzio/mezzio-template": "^2.11",
        "phpunit/phpunit": "^10.5 || ^11.5",
        "psr/container": "^1.0 || ^2.0",
        "twig/twig": "^3.21"
    },
    "autoload": {
        "psr-4": {
            "Sirix\\InertiaPsr15\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "InertiaPsr15Test\\": "test/"
        }
    },
    "config": {
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true,
            "ergebnis/composer-normalize": true
        },
        "sort-packages": true
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": false,
            "forward-command": true,
            "target-directory": "tools"
        },
        "laminas": {
            "config-provider": "Sirix\\InertiaPsr15\\ConfigProvider"
        }
    },
    "scripts": {
        "analyse-deps": "tools/composer-dependency-analyser/vendor/bin/composer-dependency-analyser",
        "benchmark": "php benchmarks/route-provider-benchmark.php",
        "benchmark-threshold": "php benchmarks/route-cache-threshold-benchmark.php",
        "check": [
            "@cs-check",
            "@rector",
            "@phpstan",
            "@test"
        ],
        "cs-check": "php tools/php-cs-fixer/vendor/bin/php-cs-fixer fix --dry-run -vvv --diff",
        "cs-fix": "php tools/php-cs-fixer/vendor/bin/php-cs-fixer fix -vvv",
        "normalize": "@composer bin composer-normalize normalize --diff ../../composer.json",
        "phpstan": "php tools/phpstan/vendor/bin/phpstan analyse -c phpstan.neon --memory-limit=2G",
        "rector": "php tools/rector/vendor/bin/rector process --dry-run --memory-limit=2G",
        "test": [
            "@test-unit"
        ],
        "test-unit": "php vendor/bin/phpunit --testsuite=unit --testdox"
    }
}
